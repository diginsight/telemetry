{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Diginsight": "Debug"
    }
  },
  "Diginsight": {
    "ActivitySources": [ "*" ],
    "LogActivities": true,
    //"Log4Net": {
    //  "Pattern": "{Timestamp|O} {Category|40} {LogLevel|5} {TraceId} {ProcessId} {Delta} {Duration} {Depth} {Indentation} {Message}"
    //},
    "Console": {
      "Patterns": {
        "1": "{Timestamp|HH:mm:ss.fff} {Category|20} {LogLevel|3} {TraceId} {Duration} {Depth} {Indentation} {Message}",
        "200": "{Timestamp|HH:mm:ss.fff} {Category|30} {LogLevel} {TraceId} {ProcessId} {Delta} {Duration} {Depth} {Indentation} {Message}"
      }
    }
  }
}
