{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Diginsight.Playground": "Debug"
    }
  },
  "Diginsight": {
    "RecordActivities": true,
    "Console": {
      "Patterns": {
        "1": "{Timestamp|HH:mm:ss.fff} {Category|20} {LogLevel|3} {TraceId} {ProcessId} {Duration} {Depth} {Indentation} {Message}",
        "200": "{Timestamp|HH:mm:ss.fff} {Category|30} {LogLevel} {TraceId} {ProcessId} {Duration} {Depth} {Indentation} {Message}"
      }
    }
  }
}
